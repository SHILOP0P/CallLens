HTTP_HOST=localhost
HTTP_PORT=8080
HTTP_READ_TIMEOUT=5s

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=calllens
POSTGRES_TEST_DB=calllens_test
POSTGRES_USER=calllens
POSTGRES_PASSWORD=change-me
POSTGRES_SSL_MODE=disable

MIGRATION_DIRECTORY=./migrations
UPLOAD_PATH=./uploads
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

LOG_LEVEL=info
LOG_AS_JSON=false

WORKER_ENABLED=true
WORKER_POLL_INTERVAL=2s
WORKER_LIMIT=1
WORKER_RETRY_DELAY=1m
WORKER_STALE_AFTER=10m
WORKER_MAX_ATTEMPTS=5

TRANSCRIBER_PROVIDER=local
TRANSCRIBER_API_KEY=
# local uses the bundled faster-whisper container. Set local-pyannote for
# timestamped speaker labels on subscriptions that include diarization.
TRANSCRIBER_MODEL=openai/whisper-large-v3
# Used only after a temporary OpenRouter 5xx from TRANSCRIBER_MODEL.
TRANSCRIBER_FALLBACK_MODEL=openai/whisper-large-v3-turbo
TRANSCRIBER_URL=http://localhost:8091
DIARIZER_URL=http://localhost:8090
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
HF_TOKEN=
PYANNOTE_DEVICE=cpu
PYANNOTE_MODEL=pyannote/speaker-diarization-community-1

ANALYZER_PROVIDER=mock
ANALYZER_API_KEY=
# Рекомендуемая недорогая OpenRouter-модель для анализа русских звонков.
ANALYZER_MODEL=mistralai/mistral-nemo

PASSWORD_PEPPER=change-me
JWT_SECRET=change-me
JWT_ACCESS_TOKEN_TTL=1h

REFRESH_TOKEN_SECRET=change-me
REFRESH_TOKEN_TTL=720h
AUTH_SESSION_TRUST_AGE=24h
